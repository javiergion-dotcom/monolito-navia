<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PAGOS</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:#eef2f5;
}

header{
  background:#17303d;
  color:white;
  padding:15px;
  display:flex;
  justify-content:space-between;
}

.contenido{
  padding:15px;
}

.bloque{
  background:white;
  padding:15px;
  border-radius:12px;
  margin-bottom:10px;
}

.fila{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:12px;
  border-bottom:1px solid #ddd;
}

.nombre{
  font-weight:bold;
}

.total{
  font-size:18px;
  font-weight:bold;
}

.botones{
  display:flex;
  gap:10px;
}

button{
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.ok{
  background:#4f8a3a;
  color:white;
}

.error{
  background:#c0392b;
  color:white;
}

</style>
</head>

<body>

<header>
  <div>PAGOS</div>
  <div onclick="volver()">←</div>
</header>

<div class="contenido" id="lista"></div>

<script>

function leerPagos(){
  return JSON.parse(localStorage.getItem("pagos_pendientes") || "[]");
}

function guardarPagos(p){
  localStorage.setItem("pagos_pendientes", JSON.stringify(p));
}

function pintar(){
  let pagos = leerPagos();
  let html="";

  pagos.forEach((p,i)=>{

    html += `
    <div class="bloque">
      <div class="fila">
        <div class="nombre">${p.proveedor}</div>
        <div class="total">${p.total.toFixed(2)} €</div>
      </div>

      <div class="botones">
        <button class="ok" onclick="pagar(${i})">✔ PAGADO</button>
        <button class="error" onclick="incidencia(${i})">⚠ INCIDENCIA</button>
      </div>
    </div>`;
  });

  document.getElementById("lista").innerHTML = html;
}

/* MARCAR PAGADO */
function pagar(i){
  let pagos = leerPagos();
  pagos[i].estado = "pagado";
  guardarPagos(pagos);
  pintar();
}

/* MARCAR INCIDENCIA */
function incidencia(i){
  let pagos = leerPagos();
  pagos[i].estado = "incidencia";
  guardarPagos(pagos);
  pintar();
}

/* VOLVER */
function volver(){
  window.location.href="index.html";
}

pintar();

</script>

</body>
</html>
