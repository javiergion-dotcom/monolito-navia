// 🔍 TEST DE CONEXIÓN DEL MONOLITO CENTRAL - REPARADO
async function comprobarConexionCloud() {
    const ahora = new Date();
    // Formato obligatorio: fecha, hora y código de camarero
    const fechaActual = ahora.toLocaleDateString('es-ES');
    const horaActual = ahora.toLocaleTimeString('es-ES');
    const codigoCamarero = "JAVI-PROY-001"; // Actualizado según nuestra última sesión

    console.log(`⏳ Iniciando test de conexión al monolito [${horaActual}]...`);

    // Paquete de prueba con el blindaje obligatorio
    const pingPrueba = {
        fecha: fechaActual,
        hora: horaActual,
        waiter_code: codigoCamarero,
        estado: "TEST_CONEXION_ACTIVO"
    };

    try {
        // Validación de la instancia DB
        if (typeof db === 'undefined') {
            throw new Error("La instancia de la base de datos 'db' no está definida. Verifica la inicialización de Firebase.");
        }

        // 1. Escritura en la colección de confianza
        await db.collection('probas_conexion').doc('ping').set(pingPrueba);
        
        // 2. Confirmación visual para el usuario
        console.log("✅ [CONEXIÓN BLINDADA]: El monolito respira en la nube.");
        console.log(`Log actualizado: ${fechaActual} ${horaActual} por ${codigoCamarero}`);
        return true;

    } catch (error) {
        // 3. Registro de error técnico
        console.error("❌ [FALLO EN EL MONOLITO]: El vínculo con la nube está obstruido.");
        console.error("Detalle técnico:", error.message);
        return false;
    }
}

// Ejecución con validación
comprobarConexionCloud();
