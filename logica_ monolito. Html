    } catch (error) {
        // 3. Si salta el error, es que las credenciales o el internet están fallando
        console.error("❌ [ERROR DE CONEXIÓN]: El dispositivo está aislado.");
        console.error("Detalle del fallo:", error.message);
        alert("Ojo, Javi: La base de datos NO está respondiendo. Revisa las claves del archivo de configuración.");
