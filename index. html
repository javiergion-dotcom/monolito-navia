<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MONOLITO</title>

<style>

body{
margin:0;
background:#111;
color:white;
font-family:Arial,Helvetica,sans-serif;
}

header{
background:#8c6a4a;
padding:20px;
text-align:center;
font-size:26px;
font-weight:bold;
}

.sub{
font-size:14px;
opacity:0.8;
margin-top:5px;
}

.panel{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
gap:18px;
padding:20px;
}

.boton{
background:#d9d2c8;
color:#222;
padding:30px 10px;
border-radius:16px;
text-align:center;
font-size:18px;
box-shadow:0 6px 0 #aaa;
transition:0.15s;
user-select:none;
}

.boton:active{
transform:translateY(4px);
box-shadow:0 2px 0 #888;
}

footer{
text-align:center;
padding:15px;
font-size:12px;
opacity:0.6;
}

</style>
</head>

<body>

<header>
MONOLITO G3F  
<div class="sub">Sistema de control profesional</div>
</header>

<div class="panel">

<div class="boton" onclick="abrir('proveedores')">Proveedores</div>
<div class="boton" onclick="abrir('pedidos')">Pedidos</div>
<div class="boton" onclick="abrir('pagos')">Pagos</div>
<div class="boton" onclick="abrir('articulos')">Artículos</div>
<div class="boton" onclick="abrir('comparador')">Comparador</div>
<div class="boton" onclick="abrir('diario')">Diario</div>
<div class="boton" onclick="abrir('radar')">Radar</div>
<div class="boton" onclick="abrir('historico')">Histórico</div>
<div class="boton" onclick="abrir('config')">Configuración</div>
<div class="boton" onclick="abrir('ventas')">Ventas</div>
<div class="boton" onclick="abrir('calendario')">Calendario</div>
<div class="boton" onclick="abrir('observaciones')">Observaciones</div>

</div>

<footer>
Operador G-3F-PAID
</footer>

<script>
function abrir(modulo){
alert("Abrir módulo: " + modulo);
}
</script>

</body>
</html>
