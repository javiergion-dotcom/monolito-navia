
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pedidos - Monolito</title>

<style>

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f2ede6;
color:#222;
}

/* CABECERA */

.header{
background:linear-gradient(90deg,#1f2a33,#2e3e4d);
color:white;
padding:16px;
display:flex;
justify-content:space-between;
align-items:center;
font-size:18px;
}

.volver{
background:#c8a27a;
border:none;
padding:8px 14px;
border-radius:10px;
cursor:pointer;
}

/* BLOQUE SUPERIOR */

.top{
padding:16px;
display:flex;
flex-direction:column;
gap:10px;
}

.top input, .top select{
padding:12px;
border-radius:10px;
border:none;
background:#e5ded3;
font-size:16px;
}

/* TABLA */

.tabla{
padding:16px;
}

.fila{
display:grid;
grid-template-columns:60px 1fr 100px;
gap:10px;
margin-bottom:10px;
}

.fila input{
padding:10px;
border-radius:10px;
border:none;
background:#e5ded3;
}

/* BOTONES + / - */

.unidades{
display:flex;
align-items:center;
gap:6px;
}

.btn{
background:#c8a27a;
border:none;
border-radius:8px;
padding:6px 10px;
font-size:16px;
}

/* TOTALES */

.totales{
padding:16px;
background:#e5ded3;
margin:16px;
border-radius:14px;
font-size:18px;
}

/* CONTROL FINAL */

.control{
display:flex;
gap:20px;
padding:16px;
}

.control label{
font-size:18px;
}

</style>

</head>

<body>

<div class="header">
<span>🧾 PEDIDOS</span>
<button class="volver" onclick="history.back()">Volver</button>
</div>

<div class="top">
<input type="text" value="Fecha: automático" readonly>
<select>
<option>Proveedor...</option>
<option>Mahou</option>
<option>Coca-Cola</option>
</select>
<input type="text" placeholder="Operario">
</div>

<div class="tabla">

<!-- FILAS -->
<div class="fila">
<div class="unidades">
<button class="btn">-</button>
<input type="number" value="1">
<button class="btn">+</button>
</div>
<input type="text" placeholder="Artículo">
<input type="text" placeholder="€" readonly>
</div>

<div class="fila">
<div class="unidades">
<button class="btn">-</button>
<input type="number">
<button class="btn">+</button>
</div>
<input type="text">
<input type="text" readonly>
</div>

<div class="fila">
<div class="unidades">
<button class="btn">-</button>
<input type="number">
<button class="btn">+</button>
</div>
<input type="text">
<input type="text" readonly>
</div>

</div>

<div class="totales">
Subtotal: 0 €<br>
IVA: 0 €<br>
<strong>TOTAL: 0 €</strong>
</div>

<div class="control">
<label><input type="checkbox"> Pagado</label>
<label><input type="checkbox"> Incidencia</label>
</div>

</body>
</html>
