<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MONOLITO</title>

<style>

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f4efe8;
color:#2b2b2b;
}

/* HEADER */

header{
background:#5a3825;
color:white;
padding:20px;
text-align:center;
font-size:22px;
font-weight:bold;
}

/* GRID */

.container{
display:grid;
grid-template-columns:1fr 1fr;
gap:14px;
padding:16px;
}

/* BOTONES */

.button{
background:#c8a27a;
padding:24px;
text-align:center;
border-radius:10px;
font-size:16px;
font-weight:700;
box-shadow:0 6px 14px rgba(0,0,0,0.25);
border-bottom:3px solid #8a6b4c;
}

.button:active{
transform:translateY(2px);
box-shadow:0 2px 6px rgba(0,0,0,0.2);
}

/* FOOTER */

.footer{
text-align:center;
padding:10px;
font-size:12px;
opacity:0.5;
}

</style>

</head>

<body>

<header>MONOLITO NAVIA</header>

<div class="container">
<div class="button">PEDIDOS</div>
<div class="button">PROVEEDORES</div>
<div class="button">ARTÍCULOS</div>
<div class="button">COMPARADOR</div>
<div class="button">VENTAS</div>
<div class="button">DIARIO</div>
</div>

<div class="footer">Sistema de control</div>

</body>
</html>
