<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pedidos - Monolito</title>

<style>
body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f2ede6;
color:#222;
}

.header{
background:#bfa58a;
color:white;
padding:20px;
text-align:center;
font-size:22px;
font-weight:bold;
}

.container{
padding:15px;
}

.fila{
display:flex;
justify-content:space-between;
align-items:center;
background:white;
padding:12px;
margin-bottom:10px;
border-radius:10px;
}

button{
padding:8px 12px;
border:none;
border-radius:8px;
background:#222;
color:white;
}

.total{
font-size:20px;
font-weight:bold;
margin-top:20px;
text-align:center;
}
</style>
</head>

<body>

<div class="header">PEDIDOS</div>

<div class="container">

<div class="fila">
<span>CERVEZA</span>
<div>
<button onclick="menos(0)">-</button>
<span id="c0">0</span>
<button onclick="mas(0)">+</button>
</div>
</div>

<div class="fila">
<span>COCA COLA</span>
<div>
<button onclick="menos(1)">-</button>
<span id="c1">0</span>
<button onclick="mas(1)">+</button>
</div>
</div>

<div class="fila">
<span>AGUA</span>
<div>
<button onclick="menos(2)">-</button>
<span id="c2">0</span>
<button onclick="mas(2)">+</button>
</div>
</div>

<div class="total">
TOTAL: <span id="total">0</span> €
</div>

</div>

<script>

let precios = [1.2, 1.5, 1.0];
let cantidades = [0,0,0];

function mas(i){
cantidades[i]++;
actualizar(i);
}

function menos(i){
if(cantidades[i]>0) cantidades[i]--;
actualizar(i);
}

function actualizar(i){
document.getElementById("c"+i).innerText = cantidades[i];

let total = 0;
for(let j=0;j<3;j++){
total += cantidades[j]*precios[j];
}

document.getElementById("total").innerText = total.toFixed(2);
}

</script>

</body>
</html>
