<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MONOLITO GPT PRO</title>

<style>
:root{
 --header:#B79C8C;
 --header-dark:#A68C7D;
 --bg:#E7E3DC;
 --card:#C9C1B3;
 --card-hover:#BFB5A6;
 --text:#1C1C1C;
 --incident:#8B1E1E;
 --comm:#D4A017;
}

body{
 margin:0;
 font-family:Arial, Helvetica, sans-serif;
 background:var(--bg);
 color:var(--text);
}

.header{
 background:linear-gradient(135deg,var(--header),var(--header-dark));
 padding:28px;
 color:white;
 text-align:center;
 box-shadow:0 6px 18px rgba(0,0,0,0.18);
}

.title{
 font-size:26px;
 font-weight:bold;
}

.subtitle{
 font-size:14px;
 opacity:0.9;
 margin-top:4px;
}

.container{
 padding:20px;
 display:grid;
 grid-template-columns:1fr 1fr;
 gap:15px;
}

.card{
 background:var(--card);
 border-radius:14px;
 padding:22px;
 text-align:center;
 font-size:18px;
 font-weight:600;
 box-shadow:0 5px 12px rgba(0,0,0,0.15);
 transition:0.15s;
}

.card:hover{
 background:var(--card-hover);
 transform:translateY(-2px);
}

.fab{
 position:fixed;
 bottom:20px;
 width:60px;
 height:60px;
 border-radius:50%;
 display:flex;
 align-items:center;
 justify-content:center;
 font-size:24px;
 color:white;
 box-shadow:0 6px 15px rgba(0,0,0,0.3);
}

.inc{
 right:20px;
 background:var(--incident);
}

.com{
 left:20px;
 background:var(--comm);
}
</style>
</head>

<body>

<div class="header">
<div class="title">MONOLITO GPT PRO</div>
<div class="subtitle">Sistema de control · El Monolito</div>
</div>

<div class="container">

<div class="card" onclick="irPedidos()">Proveedores y pedidos</div>
<div class="card">Ventas diarias</div>

<div class="card">Diario del bar</div>
<div class="card">Documentos</div>

<div class="card">Comparador de precios</div>
<div class="card">Artículos</div>

</div>

<div class="fab com">✉</div>
<div class="fab inc">!</div>

<script>
function irPedidos(){
 window.location.href = "pedidos.html";
}
</script>

</body>
</html>
