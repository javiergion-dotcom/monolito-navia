<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MONOLITO NAVIA</title>

  <style>
    body{
      margin:0;
      font-family:Arial,Helvetica,sans-serif;
      background:#0f1419;
      color:white;
    }

    header{
      background:linear-gradient(90deg,#0f2027,#203a43,#2c5364);
      padding:18px;
      text-align:center;
      box-shadow:0 4px 12px rgba(0,0,0,.4);
    }

    header h1{
      margin:0;
      font-size:22px;
    }

    header p{
      margin:5px 0 0;
      font-size:13px;
      opacity:.8;
    }

    .panel{
      padding:18px;
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:16px;
    }

    .btn{
      padding:20px;
      border-radius:14px;
      text-decoration:none;
      color:white;
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:flex-start;
      min-height:120px;
      box-shadow:0 6px 15px rgba(0,0,0,.4);
      transition:.2s;
    }

    .btn:hover{
      transform:scale(1.03);
    }

    .btn h2{
      margin:0 0 8px;
      font-size:18px;
    }

    .btn p{
      margin:0;
      font-size:13px;
      opacity:.85;
    }

    .articulos{background:#245c73;}
    .proveedores{background:#6a4c93;}
    .pedidos{background:#2f7d4f;}
    .calendario{background:#c58a18;}
    .incidencias{background:#a83232;}
    .configuracion{background:#444;}
  </style>
</head>

<body>

<header>
  <h1>MONOLITO NAVIA</h1>
  <p>Control operativo del negocio</p>
</header>

<section class="panel">

  <a class="btn articulos" href="articulos.html">
    <h2>Artículos</h2>
    <p>Base de productos</p>
  </a>

  <a class="btn proveedores" href="proveedores.html">
    <h2>Proveedores</h2>
    <p>Control de proveedores</p>
  </a>

  <a class="btn pedidos" href="pedidos.html">
    <h2>Pedidos</h2>
    <p>Control y verificación</p>
  </a>

  <a class="btn calendario" href="calendario.html">
    <h2>Calendario</h2>
    <p>Organización interna</p>
  </a>

  <a class="btn incidencias" href="incidencias.html">
    <h2>Incidencias</h2>
    <p>Registro de problemas</p>
  </a>

  <a class="btn configuracion" href="configuracion.html">
    <h2>Configuración</h2>
    <p>Ajustes del sistema</p>
  </a>

</section>

</body>
</html>
