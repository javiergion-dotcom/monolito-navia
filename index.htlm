<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>MONOLITO NAVIA</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body{
margin:0;
font-family:Arial,Helvetica,sans-serif;
background:#0f1419;
color:white;
}

/* HEADER */

header{
background:linear-gradient(90deg,#0f2027,#203a43,#2c5364);
padding:15px;
display:flex;
justify-content:space-between;
align-items:center;
box-shadow:0 4px 12px rgba(0,0,0,.4);
}

.logo{
font-size:18px;
font-weight:bold;
}

.hora{
font-size:13px;
opacity:.8;
}

/* PANEL */

.panel{
padding:15px;
display:grid;
grid-template-columns:repeat(2,1fr);
gap:12px;
}

.boton{
background:#1f2a33;
padding:25px;
border-radius:12px;
text-align:center;
cursor:pointer;
transition:.2s;
box-shadow:0 4px 10px rgba(0,0,0,.3);
}

.boton:hover{
background:#2c3e50;
}

.boton:active{
transform:scale(.95);
background:#162027;
}

/* COLORES */

.verde{background:#2e7d32;}
.naranja{background:#ef6c00;}
.azul{background:#1565c0;}
.gris{background:#37474f;}

</style>
</head>

<body>

<header>
<div class="logo">MONOLITO NAVIA</div>
<div class="hora" id="hora"></div>
</header>

<div class="panel">

<div class="boton azul">PROVEEDORES</div>
<div class="boton gris">ARTÍCULOS</div>

<div class="boton gris">PEDIDOS</div>
<div class="boton naranja">REVISIÓN</div>

<div class="boton verde">HISTÓRICO</div>
<div class="boton gris">VENTAS</div>

<div class="boton naranja">COMUNICACIÓN</div>
<div class="boton gris">CONFIGURACIÓN</div>

</div>

<script>
function actualizarHora(){
const ahora=new Date();
document.getElementById("hora").innerText=
ahora.toLocaleDateString()+" - "+ahora.toLocaleTimeString();
}
setInterval(actualizarHora,1000);
actualizarHora();
</script>

</body>
</html>
