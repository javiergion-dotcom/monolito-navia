<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pagos - Monolito</title>

<style>

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f2ede6;
color:#222;
}

.header{
background:#bfa58a;
color:white;
padding:20px;
text-align:center;
font-size:22px;
font-weight:bold;
}

.container{
padding:15px;
}

/* FILA DE PAGO */

.fila{
background:white;
border-radius:12px;
padding:15px;
margin-bottom:12px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.top{
display:flex;
justify-content:space-between;
font-weight:bold;
margin-bottom:8px;
}

.detalle{
font-size:14px;
color:#555;
margin-bottom:10px;
}

/* BOTONES */

.botones{
display:flex;
justify-content:space-between;
align-items:center;
}

.estado{
padding:6px 10px;
border-radius:10px;
font-size:13px;
}

.pendiente{background:#eee;}
.pagado{background:#4caf50;color:white;}
.incidencia{background:#b00020;color:white;}

button{
padding:8px 12px;
border:none;
border-radius:10px;
background:#222;
color:white;
}

</style>

</head>

<body>

<div class="header">PAGOS</div>

<div class="container">

<div class="fila">
<div class="top">
<span>Mahou</span>
<span>184,60 €</span>
</div>

<div class="detalle">
Pedido 25/03/2026 · Reposición
</div>

<div class="botones">
<div class="estado pendiente">Pendiente</div>
<div>
<button onclick="marcarPagado(this)">Pagado</button>
<button onclick="marcarIncidencia(this)">Incidencia</button>
</div>
</div>
</div>

<div class="fila">
<div class="top">
<span>Coca-Cola</span>
<span>96,40 €</span>
</div>

<div class="detalle">
Pedido 24/03/2026
</div>

<div class="botones">
<div class="estado pagado">Pagado</div>
<div>
<button onclick="marcarPagado(this)">Pagado</button>
<button onclick="marcarIncidencia(this)">Incidencia</button>
</div>
</div>
</div>

</div>

<script>

function marcarPagado(btn){
const estado = btn.parentElement.parentElement.querySelector('.estado');
estado.className = 'estado pagado';
estado.innerText = 'Pagado';
}

function marcarIncidencia(btn){
const estado = btn.parentElement.parentElement.querySelector('.estado');
estado.className = 'estado incidencia';
estado.innerText = 'Incidencia';
}

</script>

</body>
</html>9
