<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MONOLITO</title>

<style>

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f4efe8;
}

/* HEADER */

header{
background:#5a3825;
color:white;
padding:15px;
text-align:center;
font-size:22px;
font-weight:bold;
}

/* GRID */

.panel{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:15px;
padding:15px;
}

/* BOTONES */

.boton{
position:relative;
padding:25px;
border-radius:15px;
color:white;
font-size:16px;
font-weight:bold;
text-align:center;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

/* COLORES */

.verde{background:#2e7d32;}
.azul{background:#1565c0;}
.naranja{background:#ef6c00;}
.rojo{background:#c62828;}
.morado{background:#6a1b9a;}
.gris{background:#455a64;}

/* CONTADOR */

.contador{
position:absolute;
top:8px;
right:10px;
background:red;
color:white;
border-radius:50%;
padding:5px 8px;
font-size:12px;
}

</style>
</head>

<body>

<header>MONOLITO OK</header>

<div class="panel">

<div class="boton verde" onclick="alert('Ventas diarias')">
Ventas diarias
</div>

<div class="boton azul" onclick="alert('Diario del bar')">
Diario del bar
</div>

<div class="boton naranja" onclick="alert('Proveedores y pedidos')">
Proveedores y pedidos
<span class="contador">3</span>
</div>

<div class="boton rojo" onclick="alert('Pagos')">
Pagos
<span class="contador">1</span>
</div>

<div class="boton morado" onclick="alert('Análisis')">
Análisis
</div>

<div class="boton gris" onclick="alert('Configuración')">
Configuración
</div>

</div>

</body>
</html>
