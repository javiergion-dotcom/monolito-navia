<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MONOLITO PRO G3F</title>

<style>

*{ box-sizing:border-box; margin:0; padding:0; }

body{
background:#0e1a22;
font-family:Arial, Helvetica, sans-serif;
color:white;
overflow:hidden;
}

/* CABECERA */
.header{
background:#0c1a21;
padding:15px 20px;
display:flex;
justify-content:space-between;
align-items:center;
box-shadow:0 4px 10px rgba(0,0,0,.6);
}

.title{
font-size:22px;
font-weight:bold;
}

.info{
font-size:14px;
opacity:.8;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:18px;
padding:20px;
height:calc(100vh - 80px);
}

/* BOTONES */
.btn{
background:linear-gradient(145deg,#3e5564,#2f4654);
border-radius:20px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
font-weight:bold;
font-size:15px;
cursor:pointer;
box-shadow:6px 6px 12px rgba(0,0,0,.6), -2px -2px 8px rgba(255,255,255,.05);
transition:.1s;
position:relative;
}

.btn:active{
transform:scale(.96);
box-shadow:inset 4px 4px 10px #000;
}

.icon{
font-size:38px;
margin-bottom:10px;
}

.badge{
position:absolute;
top:8px;
right:12px;
font-size:12px;
}

/* COLORES ESPECIALES */
.orange{ background:linear-gradient(145deg,#ff9f1a,#e67e00); }
.green{ background:linear-gradient(145deg,#5bbd4a,#3f9e34); }
.red{ background:linear-gradient(145deg,#ff7b5a,#d35400); }

</style>
</head>

<body>

<div class="header">
<div class="title">MONOLITO GPT PRO</div>
<div class="info" id="hora"></div>
</div>

<div class="grid">

<div class="btn" onclick="go('proveedores.html')">
<span class="icon">🚚</span>
PROVEEDORES
<div class="badge">1</div>
</div>

<div class="btn" onclick="go('articulos.html')">
<span class="icon">📦</span>
ARTÍCULOS
</div>

<div class="btn" onclick="v()">
<span class="icon">📊</span>
COMPARADOR
</div>

<div class="btn" onclick="go('pedidos.html')">
<span class="icon">📝</span>
PEDIDOS
<div class="badge">2</div>
</div>

<div class="btn" onclick="v()">
<span class="icon">💳</span>
PAGOS
</div>

<div class="btn orange" onclick="v()">
<span class="icon">🔎</span>
REVISIÓN
<div class="badge">1</div>
</div>

<div class="btn green" onclick="v()">
<span class="icon">📁</span>
HISTÓRICO
</div>

<div class="btn" onclick="v()">
<span class="icon">💰</span>
VENTAS
</div>

<div class="btn" onclick="v()">
<span class="icon">📅</span>
CALENDARIO
</div>

<div class="btn orange" onclick="v()">
<span class="icon">✉️</span>
COMUNICACIÓN
<div class="badge">3</div>
</div>

<div class="btn orange" onclick="v()">
<span class="icon">🤖</span>
AYUDA
</div>

<div class="btn" onclick="v()">
<span class="icon">⚙️</span>
CONFIGURACIÓN
</div>

</div>

<script>

/* NAVEGACIÓN */
function go(pagina){
if(navigator.vibrate) navigator.vibrate(40);
window.location.href = pagina;
}

/* VIBRACIÓN SIMPLE */
function v(){
if(navigator.vibrate) navigator.vibrate(40);
}

/* RELOJ */
setInterval(()=>{
const now = new Date();
document.getElementById("hora").innerText =
now.toLocaleDateString()+" - "+now.toLocaleTimeString().slice(0,5);
},1000);

</script>

</body>
</html>
