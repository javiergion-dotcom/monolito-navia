<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>El Monolito</title>
<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:#0f1419;
  color:white;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  min-height:100vh;
  text-align:center;
  padding:30px 20px;
}
h1{
  font-size:38px;
  letter-spacing:2px;
  margin:0 0 10px;
}
p{
  color:#b9c1c8;
  margin:0 0 36px;
  max-width:500px;
}
.botones{
  display:flex;
  flex-direction:column;
  gap:14px;
  width:100%;
  max-width:320px;
}
.boton{
  background:#1f2a35;
  padding:16px;
  border-radius:14px;
  text-decoration:none;
  color:white;
  font-size:18px;
}
.boton:hover{
  background:#2a3947;
}
</style>
</head>
<body>

<h1>EL MONOLITO</h1>
<p>Tu sitio en Navia</p>

<div class="botones">
  <a class="boton" href="#">📘 Facebook</a>
  <a class="boton" href="#">📸 Instagram</a>
  <a class="boton" href="mailto:info@elmonolito.es">✉️ Email</a>
  <a class="boton" href="#">📍 Cómo llegar</a>
</div>

</body>
</html>
      
