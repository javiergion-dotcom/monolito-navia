<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Calendario</title>
<style>
body{font-family:Arial;margin:0;background:#f2f2f2;}
.header{background:#222;color:white;padding:14px;display:flex;justify-content:space-between;align-items:center;}
.btn{background:#3c7ec4;color:white;padding:10px 16px;border-radius:8px;text-decoration:none;}
.contenido{padding:20px;}
.bloque{background:white;padding:15px;margin-bottom:12px;border-radius:8px;box-shadow:0 2px 5px rgba(0,0,0,0.2);}
.titulo{font-weight:bold;margin-bottom:8px;}
</style>
</head>

<body>

<div class="header">
<div>📅 Calendario</div>
<a href="index.html" class="btn">← Volver</a>
</div>

<div class="contenido">
<div class="bloque"><div class="titulo">Diario del bar</div></div>
</div>

</body>
</html>
